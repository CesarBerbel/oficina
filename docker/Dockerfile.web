# ─── Dockerfile do Web (Next.js) — monorepo pnpm ───
FROM node:22-slim AS base
RUN corepack enable
WORKDIR /app

# ---- deps: apenas o subgrafo do web ----
FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/shared/package.json packages/shared/
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
RUN pnpm install --frozen-lockfile

# ---- build ----
FROM deps AS build
ENV NEXT_TELEMETRY_DISABLED=1
# Desabilita somente o lint no build de produção. O typecheck segue ativo.
ENV NEXT_DISABLE_ESLINT_DURING_BUILD=true
# URL pública da API (embutida no bundle do browser). Atrás do Nginx, /api.
ARG NEXT_PUBLIC_API_URL=/api
ARG NEXT_PUBLIC_SITE_TENANT_SLUG=
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_SITE_TENANT_SLUG=$NEXT_PUBLIC_SITE_TENANT_SLUG
COPY tsconfig.base.json ./
COPY packages/shared packages/shared
COPY apps/web apps/web
RUN pnpm --filter @oficina/shared build \
 && pnpm --filter @oficina/web build

# ---- runtime: distroless + nonroot ----
# Imagem mínima e sem shell: usa a saída "standalone" do Next (server.js +
# node_modules rastreado). static/ e public/ não entram no standalone e são
# copiados à parte. Sem native deps, então distroless é seguro aqui.
FROM gcr.io/distroless/nodejs22-debian12:nonroot AS runtime
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
WORKDIR /app
# O standalone preserva a estrutura do monorepo a partir da raiz (/app):
# server.js fica em apps/web/server.js e o node_modules mínimo na raiz.
COPY --from=build --chown=65532:65532 /app/apps/web/.next/standalone ./
COPY --from=build --chown=65532:65532 /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=65532:65532 /app/apps/web/public ./apps/web/public
EXPOSE 3000
# A ENTRYPOINT da imagem distroless já é o `node`.
CMD ["apps/web/server.js"]
