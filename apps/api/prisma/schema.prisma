// Prisma schema — Oficina (multi-tenant)
// Fase 0: fundação de acesso/auditoria. Demais módulos entram nas próximas fases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Perfis de usuário interno. Cliente acessa por token público (não é User).
enum Role {
  ADMIN
  ATENDENTE
  TECNICO
  ESTOQUISTA
}

enum CustomerType {
  PF
  PJ
}

enum FuelType {
  GASOLINA
  ETANOL
  FLEX
  DIESEL
  GNV
  ELETRICO
  HIBRIDO
}

enum TransmissionType {
  MANUAL
  AUTOMATICO
  AUTOMATIZADO
  CVT
}

enum ServiceOrderStatus {
  ENTRADA
  DIAGNOSTICO_PRONTO
  ORCAMENTO
  ORCAMENTO_APROVADO
  ORCAMENTO_RECUSADO
  AGUARDANDO_PECA
  EM_EXECUCAO
  EM_TESTE
  PRONTA
  PRONTO_RETIRAR
  ENTREGUE
  CANCELADA
}

enum ServiceOrderItemKind {
  SERVICE
  PART
}

enum PartType {
  PECA
  INSUMO
}

enum StockMovementType {
  ENTRADA
  SAIDA
  AJUSTE
  CONSUMO_OS
  COMPRA
  ESTORNO
}

/// Status da reserva formal de estoque vinculada a uma OS.
enum StockReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
  CANCELED
}

enum QuoteStatus {
  RASCUNHO
  ENVIADO
  APROVADO
  APROVADO_PARCIAL
  RECUSADO
}

enum QuoteItemDecision {
  PENDENTE
  APROVADO
  RECUSADO
}

enum QuoteDecisionType {
  TOTAL
  PARCIAL
  RECUSA
}

enum PurchaseOrderStatus {
  ABERTO
  ENVIADO
  PARCIALMENTE_RECEBIDO
  RECEBIDO
  CANCELADO
}

enum FinancialEntryType {
  RECEIVABLE
  PAYABLE
}

enum FinancialEntryStatus {
  OPEN
  PARTIAL
  PAID
  CANCELED
}

enum FinancialPaymentMethod {
  DINHEIRO
  PIX
  CARTAO_DEBITO
  CARTAO_CREDITO
  BOLETO
  TRANSFERENCIA
  CHEQUE
  OUTRO
}

enum FinancialEntryOrigin {
  MANUAL
  SERVICE_ORDER
  PURCHASE_ORDER
}

/// Tipos de conta do plano de contas simplificado.
enum AccountingAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

/// Status de um lançamento contábil de partidas dobradas.
enum AccountingJournalStatus {
  POSTED
  VOIDED
}

enum MessageEvent {
  OS_OPENED
  DIAGNOSIS_READY
  QUOTE_SENT
  QUOTE_APPROVED
  OS_IN_EXECUTION
  OS_READY
  CUSTOMER_NOTIFIED
  VEHICLE_DELIVERED
  CUSTOMER_BIRTHDAY
  MANUAL
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  SMS
}

enum MessageStatus {
  SIMULADO
  ENVIADO
  FALHA
}

enum LeadStatus {
  NOVO
  EM_ATENDIMENTO
  CONTATO_REALIZADO
  RETORNAR_DEPOIS
  AGENDADO
  CONFIRMADO
  CLIENTE_CHEGOU
  CONVERTIDO
  NAO_COMPARECEU
  CANCELADO
  PERDIDO
  DUPLICADO
  INVALIDO
  DESCARTADO
}

enum LeadContactChannel {
  TELEFONE
  WHATSAPP
  EMAIL
  PRESENCIAL
}

enum LeadContactOutcome {
  ATENDEU
  NAO_ATENDEU
  TELEFONE_INCORRETO
  CHAMAR_WHATSAPP
  PEDIU_RETORNO
  AGENDOU_VISITA
  CONFIRMOU_AGENDAMENTO
  CLIENTE_CHEGOU
  NAO_COMPARECEU
  CANCELOU_AGENDAMENTO
  SEM_INTERESSE
  JA_RESOLVEU
  ORCAMENTO_ENVIADO
  CONVERTIDO_OS
}

enum LeadConflictLevel {
  OK
  ATENCAO
  CONFLITO
  SEM_DADOS
}

enum BlogStatus {
  RASCUNHO
  PUBLICADO
}

enum AiProvider {
  OPENAI
  GEMINI
}

enum ServiceOrderEventType {
  STATUS_CHANGE
  NOTE
  CHECKLIST
  PHOTOS
  CUSTOMER_NOTIFICATION
  SYSTEM
}

enum ServiceOrderEventVisibility {
  INTERNAL
  PUBLIC
}

/// Nível do tanque de combustível registrado no check-in.
enum FuelLevel {
  EMPTY
  QUARTER
  HALF
  THREE_QUARTERS
  FULL
}

/// Oficina — raiz do multi-tenant. Toda entidade de negócio referencia um Tenant.
/// Status de uma conta (cliente do SaaS).
enum AccountStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

/// Estado operacional/verificação de um domínio customizado.
enum TenantDomainStatus {
  PENDING
  VERIFIED
  FAILED
}

/// Periodicidade comercial do plano SaaS.
enum PlanBillingInterval {
  MONTHLY
  YEARLY
}

/// Status da assinatura da conta SaaS.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

/// Features controladas por plano/quota.
enum PlanFeatureKey {
  USERS
  BRANCHES
  SERVICE_ORDERS_MONTH
  UPLOADS_MONTH
  STORAGE_MB
  AI_MONTH
  MESSAGES_MONTH
  CUSTOM_DOMAINS
}

/// Status de um pedido público de criação de conta (aprovado pelo platform admin).
enum AccountRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Plano comercial do SaaS. Limites ficam em PlanFeatureLimit.
model Plan {
  id              String              @id @default(cuid())
  code            String              @unique
  name            String
  description     String?
  active          Boolean             @default(true)
  priceCents      Int                 @default(0)
  currency        String              @default("BRL")
  billingInterval PlanBillingInterval @default(MONTHLY)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  limits         PlanFeatureLimit[]
  accounts       Account[]
  subscriptions  AccountSubscription[]
  upgradeRequests PlanUpgradeRequest[]

  @@map("plans")
}

/// Pedido de upgrade de plano feito pela conta; o super admin aprova/atribui.
model PlanUpgradeRequest {
  id        String               @id @default(cuid())
  accountId String
  planId    String
  status    AccountRequestStatus @default(PENDING)
  createdAt DateTime             @default(now())
  resolvedAt DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([accountId])
  @@map("plan_upgrade_requests")
}

/// Limite por feature de um plano. `limit=null` significa ilimitado; `enabled=false` bloqueia a feature.
model PlanFeatureLimit {
  id        String         @id @default(cuid())
  planId    String
  feature   PlanFeatureKey
  enabled   Boolean        @default(true)
  limit     Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, feature])
  @@index([feature])
  @@map("plan_feature_limits")
}

/// Assinatura atual/histórica da conta SaaS. A conta também aponta para o plano ativo em `planId`.
model AccountSubscription {
  id                 String             @id @default(cuid())
  accountId          String
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  trialEndsAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  plan    Plan    @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([accountId, status])
  @@index([planId])
  @@map("account_subscriptions")
}

/// Contador atômico por conta/feature/período para quotas mensais.
model AccountUsageCounter {
  id        String         @id @default(cuid())
  accountId String
  feature   PlanFeatureKey
  period    String         // ex.: 2026-06, ou "all" para uso cumulativo
  used      Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, feature, period])
  @@index([feature, period])
  @@map("account_usage_counters")
}

/// Pedido público de criação de conta (vindo da landing). O platform admin
/// aprova → provisiona a conta (Fase 1, PR 5).
model AccountRequest {
  id          String               @id @default(cuid())
  name        String // nome da oficina
  slug        String // subdomínio desejado
  contactName String
  email       String
  phone       String?
  message     String?
  status      AccountRequestStatus @default(PENDING)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status, createdAt])
  @@map("account_requests")
}

/// Conta do cliente (SaaS): dona de uma ou mais oficinas (matriz + filiais).
/// O `slug` é o subdomínio (ex.: "cliente" → cliente.saecbpa.com).
model Account {
  id        String        @id @default(cuid())
  name      String
  slug      String        @unique
  status    AccountStatus @default(ACTIVE)
  plan      String? // legado: código textual do plano, mantido para compatibilidade
  planId    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenants        Tenant[]
  planRef        Plan?                 @relation(fields: [planId], references: [id], onDelete: SetNull)
  subscriptions  AccountSubscription[]
  usageCounters  AccountUsageCounter[]
  upgradeRequests PlanUpgradeRequest[]

  @@index([planId])
  @@map("accounts")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?
  slug      String   @unique
  active    Boolean  @default(true)
  // Conta (cliente) dona desta oficina. Matriz e filiais compartilham a conta.
  accountId String
  // Hierarquia matriz/filial: matriz tem parentId null; filiais apontam p/ a matriz.
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent   Tenant?  @relation("TenantBranches", fields: [parentId], references: [id], onDelete: SetNull)
  branches Tenant[] @relation("TenantBranches")

  users         User[]
  loginAttempts LoginAttempt[]
  auditLogs     AuditLog[]
  customers      Customer[]
  vehicles       Vehicle[]
  serviceOrders  ServiceOrder[]
  services       Service[]
  combos         Combo[]
  parts          Part[]
  partStocks     PartStock[]
  stockMovements StockMovement[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  financialEntries FinancialEntry[]
  siteSettings   SiteSettings?
  blogPosts      BlogPost[]
  leads          Lead[]
  msgTemplates   MessageTemplate[]
  msgLogs        MessageLog[]
  aiConfig       AiConfig?
  checkins       VehicleCheckin[]
  garageCodes    GarageAccessCode[]
  categories     Category[]
  serviceOrderEvents ServiceOrderEvent[]
  receptionScheduleBlocks ReceptionScheduleBlock[]
  crmSettings CrmSettings?
  operationalSettings OperationalSettings?
  outboxMessages OutboxMessage[]
  financialLedger FinancialLedgerEntry[]
  stockReservations StockReservation[]
  accountingAccounts AccountingAccount[]
  accountingJournals AccountingJournalEntry[]
  domains TenantDomain[]
  uploadAssets UploadAsset[]

  @@index([accountId])
  @@map("tenants")
}


/// Arquivo enviado pelo módulo de uploads. A URL pública só pode ser reutilizada
/// por recursos do mesmo tenant, evitando anexar fotos externas ou de outra oficina.
model UploadAsset {
  id          String   @id @default(cuid())
  tenantId    String
  createdById String?
  filename    String   @unique
  path        String   @unique
  url         String   @unique
  mime        String
  extension   String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("UploadAssetCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([createdById])
  @@map("upload_assets")
}

/// Domínio próprio de uma oficina (SaaS multi-domínio): resolve o tenant pelo host.
model TenantDomain {
  id                String             @id @default(cuid())
  tenantId          String
  domain            String             @unique
  isPrimary         Boolean            @default(false)
  status            TenantDomainStatus @default(PENDING)
  // Token a publicar no DNS (TXT em _oficina-verify.<domain>) para comprovar posse.
  verificationToken String
  verifiedAt        DateTime?
  lastCheckedAt     DateTime?
  lastCheckError    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("tenant_domains")
}

/// Outbox transacional: eventos de notificação/mensagem persistidos junto com a
/// transação de domínio e despachados de forma assíncrona (entrega ao-menos-uma-vez).
enum OutboxStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model OutboxMessage {
  id          String       @id @default(cuid())
  tenantId    String
  type        String // ex.: ORDER_EVENT
  payload     Json
  // Chave determinística opcional: evita enfileirar duas vezes o mesmo evento de domínio.
  idempotencyKey String? @unique
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  maxAttempts Int          @default(8)
  lastError   String?
  availableAt DateTime     @default(now())
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([tenantId])
  @@index([tenantId, type])
  @@map("outbox_messages")
}

/// Funcionário do sistema.
model User {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String
  passwordHash String
  role         Role     @default(ATENDENTE)
  active       Boolean  @default(true)
  // Super usuário: acesso global a todas as oficinas (gestão da plataforma).
  superAdmin   Boolean  @default(false)
  forcePasswordChange Boolean @default(false)
  /// Versão de sessão usada para invalidar access tokens imediatamente em logout global/redefinição de senha.
  sessionVersion Int     @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens     RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs         AuditLog[]
  serviceOrders     ServiceOrder[]              @relation("TechnicianOrders")
  osStatusChanges   ServiceOrderStatusHistory[]
  stockMovements    StockMovement[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  checkins          VehicleCheckin[]            @relation("CheckinCreator")
  serviceOrderEvents ServiceOrderEvent[]        @relation("ServiceOrderEventCreator")
  uploadAssets      UploadAsset[]                @relation("UploadAssetCreator")
  receptionScheduleBlocks ReceptionScheduleBlock[] @relation("ReceptionScheduleBlockTechnician")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

/// Refresh tokens (rotação/revogação). Armazena apenas o hash do token.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ip        String?
  /// Snapshot da versão de sessão do usuário no momento da emissão.
  sessionVersion Int  @default(0)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, sessionVersion])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/// Registro de tentativas de login (sucesso/falha) para auditoria e rate limit.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  tenantId  String?
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([createdAt])
  @@map("login_attempts")
}

/// Log de auditoria de eventos importantes (CRUD, status, login, etc.).
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  module    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, module])
  @@index([tenantId, entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// Cliente da oficina (PF ou PJ). Acessa o acompanhamento por token (não é User).
model Customer {
  id         String       @id @default(cuid())
  tenantId   String
  type       CustomerType @default(PF)
  name       String
  document   String?
  phone      String?
  whatsapp   String?
  email      String?
  zip        String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  categories String[]     @default([])
  notes      String?
  birthDate  DateTime?    @db.Date
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  messageLogs   MessageLog[]
  checkins      VehicleCheckin[]
  garageCodes   GarageAccessCode[]
  financialEntries FinancialEntry[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, document])
  @@map("customers")
}

/// Veículo vinculado a um cliente.
model Vehicle {
  id           String            @id @default(cuid())
  tenantId     String
  customerId   String
  plate        String
  manufacturer String
  model        String
  modelYear    Int?
  color        String?
  fuel         FuelType?
  engine       String?
  transmission TransmissionType?
  currentKm    Int?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceOrders ServiceOrder[]
  checkins      VehicleCheckin[]
  garageCodes   GarageAccessCode[]

  @@unique([tenantId, plate])
  @@index([tenantId])
  @@index([customerId])
  @@map("vehicles")
}

/// Ordem de Serviço — núcleo do sistema.
model ServiceOrder {
  id              String             @id @default(cuid())
  tenantId        String
  number          Int
  publicToken     String             @unique
  publicTokenExpiresAt DateTime?
  status          ServiceOrderStatus @default(ENTRADA)
  customerId      String
  vehicleId       String
  technicianId    String?
  km              Int?
  reportedProblem String
  diagnosis       String?
  notes           String?
  // Travados após a abertura (cliente, veículo, km, dueDate, reportedProblem).
  dueDate         DateTime?
  totalServices   Decimal            @default(0) @db.Decimal(12, 2)
  totalParts      Decimal            @default(0) @db.Decimal(12, 2)
  discount        Decimal            @default(0) @db.Decimal(12, 2)
  total           Decimal            @default(0) @db.Decimal(12, 2)
  // Reserva de estoque ativa para as peças desta OS (aprovada, não consumida).
  partsReserved   Boolean            @default(false)
  openedAt        DateTime           @default(now())
  closedAt        DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant     Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer                    @relation(fields: [customerId], references: [id])
  vehicle    Vehicle                     @relation(fields: [vehicleId], references: [id])
  technician User?                       @relation("TechnicianOrders", fields: [technicianId], references: [id], onDelete: SetNull)
  items      ServiceOrderItem[]
  history    ServiceOrderStatusHistory[]
  quote      Quote?
  checkins   VehicleCheckin[]
  purchaseOrders PurchaseOrder[]
  events     ServiceOrderEvent[]
  financialEntries FinancialEntry[]
  stockReservations StockReservation[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([publicTokenExpiresAt])
  @@index([customerId])
  @@index([vehicleId])
  @@map("service_orders")
}

/// Item da OS (serviço ou peça). Guarda snapshot de descrição e preço.
model ServiceOrderItem {
  id             String               @id @default(cuid())
  serviceOrderId String
  kind           ServiceOrderItemKind
  description    String
  quantity       Decimal              @db.Decimal(12, 3)
  unitPrice      Decimal              @db.Decimal(12, 2)
  total          Decimal              @db.Decimal(12, 2)
  comboLabel     String?
  sourceServiceId String?
  sourcePartId    String?
  // Peça vinculada a um item de serviço (mesma OS). Usado na cascata do orçamento.
  parentItemId   String?
  createdAt      DateTime             @default(now())

  serviceOrder ServiceOrder       @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  parentItem   ServiceOrderItem?  @relation("ServiceItemParts", fields: [parentItemId], references: [id], onDelete: SetNull)
  childItems   ServiceOrderItem[] @relation("ServiceItemParts")

  @@index([serviceOrderId])
  @@index([parentItemId])
  @@map("service_order_items")
}

/// Histórico de status da OS (timeline).
model ServiceOrderStatusHistory {
  id             String             @id @default(cuid())
  serviceOrderId String
  status         ServiceOrderStatus
  note           String?
  userId         String?
  createdAt      DateTime           @default(now())

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([serviceOrderId])
  @@map("service_order_status_history")
}


/// Timeline/auditoria operacional da OS. Registra status, notas técnicas, checklist, fotos e eventos sistêmicos.
model ServiceOrderEvent {
  id             String                      @id @default(cuid())
  tenantId       String
  serviceOrderId String
  type           ServiceOrderEventType
  title          String
  description    String?
  visibility     ServiceOrderEventVisibility @default(INTERNAL)
  fromStatus     ServiceOrderStatus?
  toStatus       ServiceOrderStatus?
  checklist      Json?
  photos         String[]                    @default([])
  metadata       Json?
  createdById    String?
  createdAt      DateTime                    @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ServiceOrderEventCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([serviceOrderId, createdAt])
  @@index([tenantId, type])
  @@map("service_order_events")
}

/// Código de acesso à área do cliente (consulta do histórico do veículo pela placa).
/// O código de 6 dígitos é guardado com hash e expira em poucas horas.
model GarageAccessCode {
  id         String    @id @default(cuid())
  tenantId   String
  vehicleId  String
  customerId String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, vehicleId])
  @@index([expiresAt])
  @@map("garage_access_codes")
}

/// Serviço do catálogo (com peças padrão).
model Service {
  id               String    @id @default(cuid())
  tenantId         String
  name             String
  category         String?
  description      String?
  salePrice        Decimal   @default(0) @db.Decimal(12, 2)
  cost             Decimal   @default(0) @db.Decimal(12, 2)
  estimatedMinutes Int?
  active           Boolean   @default(true)
  // Exibir este serviço na página pública (site).
  showOnSite       Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  defaultParts ServiceDefaultPart[]
  combos       ComboService[]

  @@index([tenantId])
  @@map("services")
}

/// Peça padrão de um serviço (com quantidade padrão).
model ServiceDefaultPart {
  id        String  @id @default(cuid())
  serviceId String
  partId    String
  quantity  Decimal @db.Decimal(12, 3)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  part    Part    @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([serviceId, partId])
  @@index([serviceId])
  @@map("service_default_parts")
}

/// Combo — agrupamento interno de serviços. Expande na OS; não aparece ao cliente.
model Combo {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services ComboService[]

  @@index([tenantId])
  @@map("combos")
}

model ComboService {
  id        String @id @default(cuid())
  comboId   String
  serviceId String
  position  Int    @default(0)

  combo   Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([comboId, serviceId])
  @@index([comboId])
  @@map("combo_services")
}

/// Peça/insumo do estoque.
model Part {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  sku          String?
  ncm          String?
  ean          String?
  type         PartType @default(PECA)
  category     String?
  brand        String?
  unit         String   @default("UN")
  // Ponto de reposição (padrão do grupo). Saldo/reserva são por filial (PartStock).
  minStock     Decimal  @default(0) @db.Decimal(12, 3)
  costPrice    Decimal  @default(0) @db.Decimal(12, 2)
  salePrice    Decimal  @default(0) @db.Decimal(12, 2)
  // Fornecedor: texto legado + vínculo opcional ao cadastro de fornecedores.
  supplier     String?
  supplierId   String?
  description  String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierRef   Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements     StockMovement[]
  defaultForms  ServiceDefaultPart[]
  purchaseItems PurchaseOrderItem[]
  stocks        PartStock[]
  stockReservations StockReservation[]

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([supplierId])
  @@map("parts")
}

/// Saldo de estoque de uma peça em UMA oficina (filial). Catálogo é do grupo,
/// estoque é por filial.
model PartStock {
  id            String   @id @default(cuid())
  tenantId      String
  partId        String
  currentStock  Decimal  @default(0) @db.Decimal(12, 3)
  // Comprometido com OS aprovadas e ainda não consumidas. Disponível = current - reserved.
  reservedStock Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([tenantId, partId])
  @@index([tenantId])
  @@index([partId])
  @@map("part_stock")
}

/// Reserva formal/auditável de uma peça para uma OS.
/// O saldo agregado em `part_stock.reservedStock` continua existindo para consultas
/// rápidas, mas cada reserva passa a ter identidade, status e datas próprias.
model StockReservation {
  id             String                 @id @default(cuid())
  tenantId       String
  serviceOrderId String
  partId         String
  quantity       Decimal                @db.Decimal(12, 3)
  status         StockReservationStatus @default(ACTIVE)
  reason         String?
  createdAt      DateTime               @default(now())
  releasedAt     DateTime?
  consumedAt     DateTime?
  canceledAt     DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  part         Part         @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([serviceOrderId, status])
  @@index([partId, status])
  @@map("stock_reservations")
}

/// Fornecedor (usado em compras e na importação de NF-e).
model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  document  String?
  phone     String?
  email     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  parts          Part[]
  financialEntries FinancialEntry[]

  @@index([tenantId])
  @@index([tenantId, document])
  @@map("suppliers")
}

/// Pedido de compra.
model PurchaseOrder {
  id             String              @id @default(cuid())
  tenantId       String
  number         Int
  supplierId     String?
  // OS que originou o pedido (compra automática por falta de peça aprovada).
  serviceOrderId String?
  status         PurchaseOrderStatus @default(ABERTO)
  dueDate        DateTime?
  notes          String?
  total          Decimal             @default(0) @db.Decimal(12, 2)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier     Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  serviceOrder ServiceOrder?       @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  items        PurchaseOrderItem[]
  financialEntries FinancialEntry[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([serviceOrderId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String
  partId           String
  quantity         Decimal @db.Decimal(12, 3)
  receivedQuantity Decimal @default(0) @db.Decimal(12, 3)
  unitCost         Decimal @default(0) @db.Decimal(12, 2)
  total            Decimal @default(0) @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part          Part          @relation(fields: [partId], references: [id])

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}


/// Lançamento financeiro: contas a receber e contas a pagar.
model FinancialEntry {
  id              String                 @id @default(cuid())
  tenantId        String
  type            FinancialEntryType
  status          FinancialEntryStatus   @default(OPEN)
  origin          FinancialEntryOrigin   @default(MANUAL)
  description     String
  category        String?
  customerId      String?
  supplierId      String?
  serviceOrderId  String?
  purchaseOrderId String?
  issueDate       DateTime               @default(now())
  dueDate         DateTime
  amount          Decimal                @db.Decimal(12, 2)
  paidAmount      Decimal                @default(0) @db.Decimal(12, 2)
  remainingAmount Decimal                @default(0) @db.Decimal(12, 2)
  notes           String?
  canceledAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier      Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  serviceOrder  ServiceOrder?       @relation(fields: [serviceOrderId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  payments      FinancialPayment[]
  ledger        FinancialLedgerEntry[]
  accountingJournals AccountingJournalEntry[]

  @@unique([tenantId, serviceOrderId, type])
  @@unique([tenantId, purchaseOrderId, type])
  @@index([tenantId, type, status])
  @@index([tenantId, dueDate])
  @@index([tenantId, customerId])
  @@index([tenantId, supplierId])
  @@map("financial_entries")
}

/// Baixa/pagamento de um lançamento financeiro.
model FinancialPayment {
  id        String                 @id @default(cuid())
  tenantId  String
  entryId   String
  amount    Decimal                @db.Decimal(12, 2)
  method    FinancialPaymentMethod
  paidAt    DateTime               @default(now())
  notes     String?
  reversedAt DateTime?
  reversedById String?
  reversalReason String?
  createdAt DateTime               @default(now())

  entry FinancialEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([tenantId, paidAt])
  @@index([tenantId, reversedAt])
  @@index([entryId])
  @@map("financial_payments")
}

/// Movimento de um lançamento financeiro. Append-only/imutável (ledger):
/// `amount` é assinado pelo saldo devido (+ emite/aumenta, - baixa/estorna),
/// de modo que a soma dos movimentos == saldo restante do lançamento.
enum FinancialLedgerKind {
  ISSUE
  ADJUSTMENT
  PAYMENT
  PAYMENT_REVERSAL
  CANCELLATION
}

model FinancialLedgerEntry {
  id          String              @id @default(cuid())
  tenantId    String
  entryId     String
  kind        FinancialLedgerKind
  amount      Decimal             @db.Decimal(12, 2)
  description String?
  createdById String?
  createdAt   DateTime            @default(now())

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entry  FinancialEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([entryId])
  @@map("financial_ledger_entries")
}

/// Conta contábil por tenant. É um plano mínimo, extensível por código.
model AccountingAccount {
  id        String                @id @default(cuid())
  tenantId  String
  code      String
  name      String
  type      AccountingAccountType
  active    Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  debitLines AccountingJournalLine[] @relation("AccountingDebitAccount")
  creditLines AccountingJournalLine[] @relation("AccountingCreditAccount")

  @@unique([tenantId, code])
  @@index([tenantId, type])
  @@map("accounting_accounts")
}

/// Lançamento contábil de partidas dobradas. Cada journal precisa fechar
/// débitos == créditos, validado pela aplicação no momento da postagem.
model AccountingJournalEntry {
  id                String                  @id @default(cuid())
  tenantId          String
  financialEntryId  String?
  kind              FinancialLedgerKind
  status            AccountingJournalStatus @default(POSTED)
  description       String?
  createdById       String?
  createdAt         DateTime                @default(now())

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialEntry FinancialEntry?         @relation(fields: [financialEntryId], references: [id], onDelete: SetNull)
  lines          AccountingJournalLine[]

  @@index([tenantId, createdAt])
  @@index([financialEntryId])
  @@map("accounting_journal_entries")
}

model AccountingJournalLine {
  id               String   @id @default(cuid())
  journalEntryId   String
  debitAccountId   String
  creditAccountId  String
  amount           Decimal  @db.Decimal(12, 2)
  memo             String?
  createdAt        DateTime @default(now())

  journalEntry  AccountingJournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount  AccountingAccount      @relation("AccountingDebitAccount", fields: [debitAccountId], references: [id])
  creditAccount AccountingAccount      @relation("AccountingCreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@index([debitAccountId])
  @@index([creditAccountId])
  @@map("accounting_journal_lines")
}

/// Notificação interna para um usuário.
model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  entity    String?
  entityId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Inscrição de Web Push (VAPID) por dispositivo do usuário.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

/// Configurações do site público (singleton por oficina).
model SiteSettings {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  shopName     String
  tagline      String?
  // Sobre: resumo (home/topo do Sobre) + texto complementar (restante do Sobre).
  about        String?
  aboutExtra   String?
  heroTitle    String?
  heroSubtitle String?
  phone        String?
  whatsapp     String?
  email        String?
  cnpj         String?
  // Endereço: campos estruturados; `address` guarda a versão composta p/ exibição.
  address           String?
  addressZip        String?
  addressStreet     String?
  addressNumber     String?
  addressComplement String?
  addressDistrict   String?
  addressCity       String?
  addressState      String?
  hours        String?
  mapsEmbed    String?
  instagram    String?
  facebook     String?
  logoUrl       String?
  logoPdfUrl    String?
  pdfFooterText String?
  // Imagem padrão dos artigos do blog (quando o artigo não tem imagem própria).
  blogFallbackImageUrl String?
  // Imagem exibida nos cards de serviço da página pública.
  serviceCardImageUrl String?
  // Imagem de fundo do hero (topo) da home pública.
  heroImageUrl String?
  capacity      Int?
  published     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("site_settings")
}

/// Tipo de categoria: cliente, serviço ou peça.
enum CategoryKind {
  CUSTOMER
  SERVICE
  PART
  BRAND
}

/// Categoria cadastrável (por tipo) — vinculada a clientes, serviços e peças.
model Category {
  id        String       @id @default(cuid())
  tenantId  String
  kind      CategoryKind
  name      String
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, kind, name])
  @@index([tenantId, kind])
  @@map("categories")
}


/// Configurações do CRM de pós-venda e retenção.
model CrmSettings {
  id        String   @id @default(cuid())
  tenantId  String   @unique

  enabled Boolean @default(true)

  reviewIntervalDays Int @default(180)
  reviewIntervalKm Int @default(10000)
  reviewKmWarning Int @default(1000)
  inactiveCustomerDays Int @default(365)
  postDeliveryStartDays Int @default(3)
  postDeliveryEndDays Int @default(21)
  refusedQuoteRecoveryDays Int @default(45)
  refusedQuoteMinimumAgeDays Int @default(15)
  highPriorityDays Int @default(365)
  mediumPriorityDays Int @default(210)

  enablePreventiveReview Boolean @default(true)
  enableKmReview Boolean @default(true)
  enableInactiveCustomers Boolean @default(true)
  enablePostDeliveryReturn Boolean @default(true)
  enableRefusedQuoteRecovery Boolean @default(true)
  enableRecommendedMaintenance Boolean @default(true)
  enableSeasonalCampaigns Boolean @default(true)

  recommendedMaintenanceKeywords String[] @default(["recomend", "retornar", "acompanhar", "atenção", "preventiva"])
  seasonalCampaigns Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("crm_settings")
}


/// Configurações do dashboard operacional e inbox unificado.
model OperationalSettings {
  id        String   @id @default(cuid())
  tenantId  String   @unique

  appointmentLookaheadHours Int @default(12)
  waitingCustomerMinutes Int @default(30)
  stalledServiceOrderHours Int @default(24)
  pendingApprovalHours Int @default(24)
  crmHighPriorityLimit Int @default(10)

  enableAppointmentAlerts Boolean @default(true)
  enableWaitingCustomerAlerts Boolean @default(true)
  enableStalledOsAlerts Boolean @default(true)
  enablePendingApprovalAlerts Boolean @default(true)
  enableCrmAlerts Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("operational_settings")
}

/// Configuração do assistente de IA (singleton por oficina). Chave criptografada.
model AiConfig {
  id           String     @id @default(cuid())
  tenantId     String     @unique
  provider     AiProvider @default(OPENAI)
  apiKeyEnc    String?
  instructions String?
  // Instruções específicas por campo (mapa campo → instrução).
  fieldInstructions Json?
  active       Boolean    @default(false)
  // Limites de uso (null = ilimitado). Contam chamadas à IA no período.
  dailyLimit        Int?
  monthlyLimit      Int?
  perUserDailyLimit Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

/// Log de uso da IA (uma linha por chamada de assistente/artigo).
model AiUsageLog {
  id          String     @id @default(cuid())
  tenantId    String
  userId      String?
  kind        String // 'assist' | 'article'
  field       String? // AiFieldKey (quando assist)
  provider    AiProvider
  success     Boolean
  error       String?
  inputChars  Int        @default(0)
  outputChars Int        @default(0)
  totalTokens Int?
  createdAt   DateTime   @default(now())

  @@index([tenantId, createdAt])
  @@map("ai_usage_logs")
}

/// Artigo do blog.
model BlogPost {
  id             String     @id @default(cuid())
  tenantId       String
  title          String
  slug           String
  excerpt        String?
  content        String
  imageUrl       String?
  author         String?
  status         BlogStatus @default(RASCUNHO)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@map("blog_posts")
}

/// Atendimento recebido pelo site/recepção e tratado na Central de Atendimento.
model Lead {
  id                      String            @id @default(cuid())
  tenantId                String
  name                    String
  phone                   String
  email                   String?
  plate                   String?
  vehicle                 String?
  message                 String
  status                  LeadStatus        @default(NOVO)
  assignedToId            String?
  assignedToName          String?
  matchedCustomerId       String?
  matchedVehicleId        String?
  convertedCustomerId     String?
  convertedVehicleId      String?
  convertedServiceOrderId String?
  conflictLevel           LeadConflictLevel @default(SEM_DADOS)
  conflictReason          String?
  nextFollowUpAt          DateTime?
  appointmentStartAt      DateTime?
  appointmentEndAt        DateTime?
  appointmentServiceType  String?
  appointmentNotes        String?
  appointmentConfirmedAt  DateTime?
  checkedInAt             DateTime?
  noShowAt                DateTime?
  appointmentCanceledAt   DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  convertedAt             DateTime?
  closedAt                DateTime?

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactAttempts LeadContactAttempt[]
  events          LeadEvent[]

  @@index([tenantId, status])
  @@index([tenantId, plate])
  @@index([tenantId, nextFollowUpAt])
  @@index([tenantId, appointmentStartAt])
  @@index([tenantId, matchedCustomerId])
  @@map("leads")
}

/// Bloqueio operacional da agenda da Recepção.
model ReceptionScheduleBlock {
  id           String   @id @default(cuid())
  tenantId     String
  technicianId String?
  title        String
  notes        String?
  startAt      DateTime
  endAt        DateTime
  createdById  String?
  createdByName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  technician User?  @relation("ReceptionScheduleBlockTechnician", fields: [technicianId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
  @@index([tenantId, technicianId, startAt])
  @@map("reception_schedule_blocks")
}

/// Registro de contato feito pelo atendente durante a jornada do atendimento.
model LeadContactAttempt {
  id             String             @id @default(cuid())
  tenantId       String
  leadId         String
  userId         String?
  userName       String?
  channel        LeadContactChannel
  outcome        LeadContactOutcome
  notes          String?
  nextFollowUpAt DateTime?
  createdAt      DateTime           @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId, createdAt])
  @@index([tenantId, nextFollowUpAt])
  @@map("lead_contact_attempts")
}

/// Timeline operacional da Central de Atendimento/Recepção.
model LeadEvent {
  id          String   @id @default(cuid())
  tenantId    String
  leadId      String
  userId      String?
  userName    String?
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([tenantId, leadId, createdAt])
  @@index([tenantId, type])
  @@map("lead_events")
}

/// Template de mensagem (por evento + canal).
model MessageTemplate {
  id        String         @id @default(cuid())
  tenantId  String
  name      String
  event     MessageEvent   @default(MANUAL)
  channel   MessageChannel @default(WHATSAPP)
  body      String
  active    Boolean        @default(true)
  autoSend  Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, event])
  @@map("message_templates")
}

/// Histórico de mensagens enviadas (ou simuladas).
model MessageLog {
  id             String         @id @default(cuid())
  tenantId       String
  templateId     String?
  customerId     String?
  serviceOrderId String?
  channel        MessageChannel
  event          MessageEvent   @default(MANUAL)
  dispatchKey    String?        @unique
  status         MessageStatus  @default(SIMULADO)
  to             String?
  body           String
  error          String?
  createdAt      DateTime       @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, event, serviceOrderId])
  @@map("message_logs")
}

/// Orçamento vinculado à OS — snapshot dos itens para aprovação do cliente.
model Quote {
  id              String            @id @default(cuid())
  tenantId        String
  serviceOrderId  String            @unique
  status          QuoteStatus       @default(ENVIADO)
  // Quantas vezes o orçamento foi enviado/gerado (reenvios exigem motivo).
  sendCount       Int               @default(0)
  publicNotes     String?
  totalServices   Decimal           @default(0) @db.Decimal(12, 2)
  totalParts      Decimal           @default(0) @db.Decimal(12, 2)
  discount        Decimal           @default(0) @db.Decimal(12, 2)
  total           Decimal           @default(0) @db.Decimal(12, 2)
  decisionType    QuoteDecisionType?
  decidedAt       DateTime?
  decisionIp      String?
  decisionUa      String?
  signatureName   String?
  signatureDoc    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  items        QuoteItem[]

  @@index([tenantId])
  @@map("quotes")
}

model QuoteItem {
  id          String               @id @default(cuid())
  quoteId     String
  kind        ServiceOrderItemKind
  description String
  quantity    Decimal              @db.Decimal(12, 3)
  unitPrice   Decimal              @db.Decimal(12, 2)
  discountPercent Decimal           @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal           @default(0) @db.Decimal(12, 2)
  total       Decimal              @db.Decimal(12, 2)
  decision    QuoteItemDecision    @default(PENDENTE)
  // Item de peça vinculado ao item de serviço (mesmo orçamento) — cascata.
  parentItemId String?
  // Item da OS que originou esta linha do orçamento (snapshot, sem FK). Usado
  // para remover da OS os itens recusados quando o cliente aprova parcialmente.
  serviceOrderItemId String?

  quote      Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  parentItem QuoteItem?  @relation("QuoteItemParts", fields: [parentItemId], references: [id], onDelete: SetNull)
  childItems QuoteItem[] @relation("QuoteItemParts")

  @@index([quoteId])
  @@map("quote_items")
}

/// Movimentação de estoque. Toda mudança de saldo passa por aqui.
model StockMovement {
  id           String            @id @default(cuid())
  tenantId     String
  partId       String
  type         StockMovementType
  quantity     Decimal           @db.Decimal(12, 3)
  unitCost     Decimal?          @db.Decimal(12, 2)
  balanceAfter Decimal           @db.Decimal(12, 3)
  note         String?
  serviceOrderId String?
  userId       String?
  createdAt    DateTime          @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  part   Part   @relation(fields: [partId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([partId])
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

/// Check-in de entrada do veículo: estado no recebimento (KM, combustível,
/// avarias, checklist, fotos e assinatura do responsável). Pode estar avulso
/// ou vinculado a uma OS.
model VehicleCheckin {
  id             String     @id @default(cuid())
  tenantId       String
  vehicleId      String
  customerId     String
  serviceOrderId String
  km             Int?
  fuelLevel      FuelLevel?
  /// Avarias marcadas sobre o diagrama: [{ x, y, severity, description }]
  damages        Json       @default("[]")
  /// Itens de inspeção: [{ item, status, note }]
  checklist      Json       @default("[]")
  /// URLs das fotos enviadas.
  photos         String[]   @default([])
  signatureUrl   String?
  signedBy       String?
  notes          String?
  createdById    String?
  createdAt      DateTime   @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicle      Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceOrder ServiceOrder  @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("CheckinCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([vehicleId])
  @@index([customerId])
  @@index([serviceOrderId])
  @@map("vehicle_checkins")
}

/// Heartbeat operacional global (ex.: último backup bem-sucedido) para métricas/alertas.
model OpsHeartbeat {
  key       String   @id
  at        DateTime
  note      String?
  updatedAt DateTime @updatedAt

  @@map("ops_heartbeat")
}
